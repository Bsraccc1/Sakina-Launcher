<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="28dp"
        android:background="@drawable/bg_unified_dialog"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="22dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/dialogTitle"
            style="@style/TextLarge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_semibold"
            android:letterSpacing="0.01"
            android:textColor="?attr/primaryColor"
            android:textSize="22sp" />

        <LinearLayout
            android:id="@+id/dialogInputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dialogNegative"
                style="@style/TextSmallBold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_selector_row"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:minWidth="84dp"
                android:paddingHorizontal="18dp"
                android:paddingVertical="10dp"
                android:textColor="?attr/primaryColor" />

            <TextView
                android:id="@+id/dialogPositive"
                style="@style/TextSmallBold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_note_segment_selected"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:minWidth="84dp"
                android:paddingHorizontal="18dp"
                android:paddingVertical="10dp"
                android:textColor="?attr/primaryColor" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
