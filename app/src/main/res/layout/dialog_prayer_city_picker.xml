<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:layout_marginHorizontal="20dp"
        android:layout_marginVertical="56dp"
        android:animateLayoutChanges="true"
        android:background="@drawable/bg_unified_dialog"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="22dp"
        android:paddingBottom="18dp">

        <TextView
            style="@style/TextLarge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_semibold"
            android:letterSpacing="0.01"
            android:text="@string/prayer_region"
            android:textColor="?attr/primaryColor"
            android:textSize="22sp" />

        <EditText
            android:id="@+id/searchInput"
            style="@style/TextMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_note_composer"
            android:hint="@string/search"
            android:imeOptions="actionSearch"
            android:inputType="textCapWords"
            android:maxLines="1"
            android:paddingHorizontal="20dp"
            android:paddingVertical="14dp"
            android:textColor="?attr/primaryColor"
            android:textColorHint="?attr/primaryColorTrans50" />

        <ListView
            android:id="@+id/cityList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="6dp"
            android:layoutAnimation="@anim/layout_anim_from_bottom"
            android:overScrollMode="never"
            android:scrollbars="none"
            tools:listitem="@layout/adapter_prayer_location" />

        <TextView
            android:id="@+id/emptyView"
            style="@style/TextSmallLight"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:alpha="0.62"
            android:gravity="center"
            android:text="@string/no_results"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
