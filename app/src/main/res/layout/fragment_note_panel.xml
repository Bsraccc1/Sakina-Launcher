<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="@drawable/bg_note_panel_scrim"
    android:orientation="vertical">

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:layout_weight="0.05" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/title"
            style="@style/TextMedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:text="@string/notes" />

        <FrameLayout
            android:id="@+id/modeSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_note_composer"
            android:padding="3dp">

            <!-- Sliding pill indicator that animates behind the active segment label -->
            <View
                android:id="@+id/segmentIndicator"
                android:layout_width="66dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_note_segment_selected" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/notesTab"
                    style="@style/TextSmall"
                    android:layout_width="66dp"
                    android:layout_height="34dp"
                    android:gravity="center"
                    android:text="@string/notes" />

                <TextView
                    android:id="@+id/todoTab"
                    style="@style/TextSmall"
                    android:layout_width="66dp"
                    android:layout_height="34dp"
                    android:gravity="center"
                    android:text="@string/todo" />

                <TextView
                    android:id="@+id/timerTab"
                    style="@style/TextSmall"
                    android:layout_width="66dp"
                    android:layout_height="34dp"
                    android:gravity="center"
                    android:text="@string/timer" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/contentFrame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:fadingEdgeLength="24dp"
            android:layoutAnimation="@anim/layout_anim_from_bottom"
            android:paddingTop="8dp"
            android:paddingBottom="14dp"
            android:requiresFadingEdge="vertical" />

        <TextView
            android:id="@+id/emptyState"
            style="@style/TextSmallLight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:alpha="0.55"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:text="@string/no_notes_yet"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/timerLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="248dp"
                android:layout_height="248dp">

                <app.sakinalauncher.ui.view.CircularTimerView
                    android:id="@+id/timerProgress"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/timerValue"
                        style="@style/TextLarge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="25:00"
                        android:textSize="46sp" />

                    <TextView
                        android:id="@+id/timerStart"
                        style="@style/TextSmallBold"
                        android:layout_width="112dp"
                        android:layout_height="42dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_timer_start_button"
                        android:drawablePadding="7dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:text="@string/start"
                        android:textColor="?attr/primaryColor"
                        app:drawableStartCompat="@drawable/ic_play"
                        app:drawableTint="?attr/primaryColor" />

                </LinearLayout>

            </FrameLayout>

            <LinearLayout
                android:id="@+id/timerControls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/timerPause"
                    style="@style/TextSmallBold"
                    android:layout_width="92dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_note_composer"
                    android:gravity="center"
                    android:text="@string/pause" />

                <TextView
                    android:id="@+id/timerReset"
                    style="@style/TextSmallBold"
                    android:layout_width="92dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_note_composer"
                    android:gravity="center"
                    android:text="@string/reset" />

            </LinearLayout>

            <TextView
                android:id="@+id/timerHint"
                style="@style/TextSmallLight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:alpha="0.62"
                android:gravity="center"
                android:text="@string/tap_timer_to_set_duration" />

        </LinearLayout>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/composer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/bg_note_composer"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/input"
            style="@style/TextMedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:hint="@string/write_note"
            android:imeOptions="actionSend"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLength="2000"
            android:maxLines="4"
            android:minLines="1"
            android:paddingStart="18dp"
            android:paddingEnd="10dp"
            android:paddingVertical="12dp"
            android:textColorHint="?attr/primaryColorTrans50" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/send"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_note_send_button"
            android:contentDescription="@string/send"
            android:padding="10dp"
            android:src="@drawable/ic_send" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/noteActionBar"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:layout_marginHorizontal="30dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/bg_note_action_bar"
        android:elevation="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:visibility="gone">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/noteActionDelete"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_note_action_button"
            android:contentDescription="@string/delete_note"
            android:padding="10dp"
            android:src="@drawable/ic_delete"
            app:tint="#F22B3A" />

        <TextView
            android:id="@+id/noteActionSelectAll"
            style="@style/TextSmallBold"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_note_count_pill"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:text="All"
            android:textColor="?attr/primaryColor" />

        <TextView
            android:id="@+id/noteSelectionCount"
            style="@style/TextSmallBold"
            android:layout_width="34dp"
            android:layout_height="28dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_note_count_pill"
            android:gravity="center"
            android:text="1"
            android:textColor="?attr/primaryInverseColor" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/noteActionEdit"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_note_action_button"
            android:contentDescription="@string/edit_note"
            android:padding="10dp"
            android:src="@drawable/ic_rename"
            app:tint="?attr/primaryColor" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/noteActionCopy"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_note_action_button"
            android:contentDescription="@string/copy"
            android:padding="10dp"
            android:src="@drawable/ic_copy"
            app:tint="?attr/primaryColor" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/noteActionDone"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_note_action_button"
            android:contentDescription="@string/note_done"
            android:padding="10dp"
            android:src="@drawable/ic_check"
            app:tint="?attr/primaryColor" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/noteActionClose"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_note_action_button"
            android:contentDescription="@string/close"
            android:padding="10dp"
            android:src="@drawable/ic_close"
            app:tint="?attr/primaryColor" />

    </LinearLayout>

</LinearLayout>
