<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_note_panel_scrim"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:paddingHorizontal="20dp"
    android:paddingTop="32dp"
    android:paddingBottom="28dp"
    android:scrollbars="none">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header: period title + card position -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/title"
                style="@style/TextLarge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/poppins_semibold"
                android:letterSpacing="0.01"
                android:maxLines="1"
                android:textSize="24sp"
                tools:text="Morning dhikr" />

            <TextView
                android:id="@+id/counter"
                style="@style/TextSmallBold"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/bg_note_composer"
                android:gravity="center"
                android:letterSpacing="0.04"
                android:minWidth="78dp"
                android:paddingHorizontal="16dp"
                android:textSize="13sp"
                tools:text="1 of 24" />

        </LinearLayout>

        <!-- Content card -->
        <LinearLayout
            android:id="@+id/contentCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:minHeight="380dp"
            android:background="@drawable/bg_unified_card"
            android:orientation="vertical"
            android:paddingHorizontal="22dp"
            android:paddingTop="20dp"
            android:paddingBottom="18dp">

            <TextView
                android:id="@+id/cardTitle"
                style="@style/TextLarge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semibold"
                android:gravity="center"
                android:lineSpacingExtra="1dp"
                android:maxLines="2"
                android:textSize="19sp"
                tools:text="Ayat al-Kursi" />

            <TextView
                android:id="@+id/repetition"
                style="@style/TextSmallBold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_dhikr_repeat_chip"
                android:letterSpacing="0.04"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:shadowColor="@android:color/transparent"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="0"
                android:textColor="?attr/primaryColor"
                android:textSize="11sp"
                tools:text="Read 3 times" />

            <!-- Arabic: autosize to fit, never truncated. Largest share of the card. -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/arabic"
                style="@style/TextArabic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:lineSpacingExtra="8dp"
                android:tag="arabic"
                android:textDirection="rtl"
                app:autoSizeMaxTextSize="28sp"
                app:autoSizeMinTextSize="13sp"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform"
                tools:text="بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ" />

            <View
                android:layout_width="52dp"
                android:layout_height="2dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:alpha="0.4"
                android:background="?attr/primaryColor" />

            <!-- Transliteration -->
            <TextView
                style="@style/TextSmallBold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_marginTop="10dp"
                android:alpha="0.5"
                android:letterSpacing="0.18"
                android:text="@string/dhikr_section_translit"
                android:textAllCaps="true"
                android:textColor="?attr/primaryColor"
                android:textSize="10sp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/latin"
                style="@style/TextSmallLight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="2dp"
                android:textStyle="italic"
                app:autoSizeMaxTextSize="14sp"
                app:autoSizeMinTextSize="9sp"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform"
                tools:text="Bismillahir-rahmanir-rahim..." />

            <!-- Meaning -->
            <TextView
                style="@style/TextSmallBold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_marginTop="10dp"
                android:alpha="0.5"
                android:letterSpacing="0.18"
                android:text="@string/dhikr_section_meaning"
                android:textAllCaps="true"
                android:textColor="?attr/primaryColor"
                android:textSize="10sp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/meaning"
                style="@style/TextSmallLight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.85"
                android:lineSpacingExtra="2dp"
                app:autoSizeMaxTextSize="14sp"
                app:autoSizeMinTextSize="9sp"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform"
                tools:text="With the name of Allah..." />

            <!-- Counter progress -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="12dp"
                android:max="100"
                android:progress="0"
                android:progressBackgroundTint="?attr/primaryColorTrans50"
                android:progressTint="?attr/primaryColor" />

        </LinearLayout>

        <!-- Navigation + tap counter (capsule) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnPrev"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_dhikr_nav_button"
                android:clickable="true"
                android:contentDescription="@string/previous"
                android:focusable="true"
                android:padding="14dp"
                android:src="@drawable/ic_chevron_left" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tasbihCounter"
                    style="@style/TextLarge"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:background="@drawable/bg_tasbih_capsule"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_semibold"
                    android:gravity="center"
                    android:letterSpacing="0.02"
                    android:textColor="?attr/primaryColor"
                    android:textSize="26sp"
                    tools:text="0 / 3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:alpha="0.6"
                    android:letterSpacing="0.14"
                    android:text="@string/dhikr_tap_to_count"
                    android:textAllCaps="true"
                    android:textColor="?attr/primaryColor"
                    android:textSize="10sp" />

            </LinearLayout>

            <ImageView
                android:id="@+id/btnNext"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_dhikr_nav_button"
                android:clickable="true"
                android:contentDescription="@string/next"
                android:focusable="true"
                android:padding="14dp"
                android:src="@drawable/ic_chevron_right" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
