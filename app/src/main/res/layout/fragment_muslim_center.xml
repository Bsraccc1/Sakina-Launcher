<?xml version="1.0" encoding="utf-8"?>
<app.sakinalauncher.ui.view.SwipeAwareScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollView"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_note_panel_scrim"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/title"
            style="@style/TextLarge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/muslim_center" />

        <LinearLayout
            android:id="@+id/prayerCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/rounded_rect_shade_color"
            android:clickable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                style="@style/TextSmallLight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.72"
                android:text="@string/prayer_times" />

            <LinearLayout
                android:id="@+id/nextPrayerHero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/nextPrayerName"
                    style="@style/TextLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    tools:text="Maghrib" />

                <TextView
                    android:id="@+id/nextPrayer"
                    style="@style/TextLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="36sp"
                    tools:text="18:08" />

                <TextView
                    style="@style/TextSmallLight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:alpha="0.62"
                    android:text="@string/next_prayer" />

            </LinearLayout>

            <TextView
                android:id="@+id/location"
                style="@style/TextSmallLight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:alpha="0.62"
                android:gravity="center"
                android:text="@string/set_location_placeholder" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:baselineAligned="false"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/subuhTime"
                    style="@style/TextSmall"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_prayer_time_chip"
                    android:gravity="center"
                    android:textAlignment="center"
                    tools:text="Subuh\n04:39" />

                <TextView
                    android:id="@+id/dzuhurTime"
                    style="@style/TextSmall"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_prayer_time_chip"
                    android:gravity="center"
                    android:textAlignment="center"
                    tools:text="Dzuhur\n11:56" />

                <TextView
                    android:id="@+id/asharTime"
                    style="@style/TextSmall"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_prayer_time_chip"
                    android:gravity="center"
                    android:textAlignment="center"
                    tools:text="Ashar\n15:17" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:baselineAligned="false"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/maghribTime"
                    style="@style/TextSmall"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_prayer_time_chip"
                    android:gravity="center"
                    android:textAlignment="center"
                    tools:text="Maghrib\n17:49" />

                <TextView
                    android:id="@+id/isyaTime"
                    style="@style/TextSmall"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_prayer_time_chip"
                    android:gravity="center"
                    android:textAlignment="center"
                    tools:text="Isya\n19:02" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:visibility="invisible" />

            </LinearLayout>

            <TextView
                android:id="@+id/prayerSource"
                style="@style/TextSmallLight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:alpha="0.62"
                android:gravity="center"
                tools:text="Source: Kemenag RI" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/morningDhikrCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/rounded_rect_shade_color"
            android:clickable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                style="@style/TextMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dzikir_pagi" />

            <TextView
                android:id="@+id/morningDhikr"
                style="@style/TextSmallLight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:alpha="0.72"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/eveningDhikrCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/rounded_rect_shade_color"
            android:clickable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                style="@style/TextMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dzikir_petang" />

            <TextView
                android:id="@+id/eveningDhikr"
                style="@style/TextSmallLight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:alpha="0.72"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/source"
            style="@style/TextSmallBold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:padding="10dp"
            android:text="@string/dzikir_source" />

    </LinearLayout>

</app.sakinalauncher.ui.view.SwipeAwareScrollView>
